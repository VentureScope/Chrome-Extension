{
  "manifest_version": 3,
  "name": "VentureScope Academic Sync",
  "version": "1.0.0",
  "description": "Sync your academic data from eStudent portal to VentureScope",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>", "https://estudent.astu.edu.et/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.jpg",
      "48": "icons/icon48.jpg",
      "128": "icons/icon128.jpg"
    }
  },
  "icons": {
    "16": "icons/icon16.jpg",
    "48": "icons/icon48.jpg",
    "128": "icons/icon128.jpg"
  },
  "background": {
    "service_worker": "background.js"
  }
}
